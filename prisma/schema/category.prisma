model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique 
  description String?  @db.Text
  icon        String?  
  isActive    Boolean  @default(true) 
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]

  @@map("categories")
}