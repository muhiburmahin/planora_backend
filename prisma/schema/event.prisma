model Event {
  id               String      @id @default(uuid())
  title            String
  slug             String      @unique 
  shortDescription String?     @db.VarChar(255)
  description      String      @db.Text
  date             DateTime
  time             String
  venue            String     
  isOnline         Boolean     @default(false) 
  type             EventType   @default(PUBLIC)
  registrationFee  Float       @default(0)
  maxParticipants  Int?        @default(0)    
  status           EventStatus @default(UPCOMING)
  isPublished      Boolean     @default(true)
  isFeatured       Boolean     @default(false) 
  
  images           EventImage[] 
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id], onUpdate: Cascade)
  organizerId      String
  organizer        User        @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  participations   Participation[]
  averageRating    Float    @default(0)
  totalReviews     Int      @default(0)
  reviews          Review[]
  invitations      Invitation[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

model EventImage {
  id      String @id @default(uuid())
  url     String
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("event_images")
}