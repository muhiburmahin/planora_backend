{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",                              
    "rootDir": "./src",
    "outDir": "./dist",  
    //"moduleResolution": "node10", 
     "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
    "include": ["src/**/*"],
  "exclude": ["node_modules"]
}



